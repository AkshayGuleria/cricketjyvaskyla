---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Gallery from '../components/Gallery.astro';
import galleryData from '../data/gallery.json';
---

<BaseLayout
  title="Gallery - Jyväskylä Cricket Club"
  description="Browse photos from Jyväskylä Cricket Club matches, events, and memorable moments."
>
  <Header slot="header" />

  <div class="container">
    <div class="page-header">
      <h1>Photo Gallery</h1>
      <p class="lead">
        Relive the best moments from our matches, tournaments, and club events.
      </p>
    </div>

    <div class="gallery-content">
      <!-- Gallery Albums -->
      {galleryData.albums.map((album) => (
        <section class="album-section">
          <div class="album-header">
            <div class="album-info">
              <h2>{album.title}</h2>
              <p class="album-description">{album.description}</p>
              <div class="album-meta">
                <span class="meta-item">📅 {album.date}</span>
                <span class="meta-item">📍 {album.location}</span>
                {album.images.length > 0 && (
                  <span class="meta-item">📸 {album.images.length} photos</span>
                )}
              </div>
            </div>
          </div>

          <Gallery images={album.images} albumId={album.id} />
        </section>
      ))}

      <!-- Call to Action -->
      <div class="cta-section">
        <h3>Have Photos to Share?</h3>
        <p>
          If you have photos from club events or matches that you'd like to contribute to our gallery, please get in touch!
        </p>
        <a href="/contact" class="btn-primary">
          Contact Us
        </a>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem 0;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--color-neutral-900);
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .lead {
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    line-height: 1.6;
    color: var(--color-neutral-600);
    max-width: 700px;
    margin: 0 auto;
  }

  .gallery-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Album Section */
  .album-section {
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-neutral-200);
  }

  .album-section:last-of-type {
    border-bottom: none;
  }

  .album-header {
    margin-bottom: 2rem;
  }

  .album-info h2 {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-neutral-900);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .album-description {
    font-size: 1.05rem;
    color: var(--color-neutral-600);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .album-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .meta-item {
    font-size: 0.9rem;
    color: var(--color-neutral-500);
    padding: 0.375rem 0.75rem;
    background: var(--color-neutral-50);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-neutral-200);
  }

  /* CTA Section */
  .cta-section {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-neutral-50);
    border-radius: var(--radius-lg);
  }

  .cta-section h3 {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-neutral-900);
    margin-bottom: 0.75rem;
  }

  .cta-section p {
    font-size: 1.05rem;
    color: var(--color-neutral-600);
    margin-bottom: 1.5rem;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-primary {
    display: inline-block;
    padding: 1rem 2rem;
    background: var(--color-primary);
    color: var(--color-neutral-100);
    border-radius: var(--radius-md);
    text-decoration: none;
    font-weight: 600;
    transition: all var(--transition-base);
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 53, 128, 0.3);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .page-header {
      margin-bottom: 2rem;
      padding: 1rem 0;
    }

    .album-section {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
    }

    .album-info h2 {
      font-size: 1.5rem;
    }

    .album-meta {
      gap: 0.5rem;
    }

    .meta-item {
      font-size: 0.85rem;
      padding: 0.25rem 0.5rem;
    }

    .cta-section {
      padding: 2rem 1.5rem;
    }
  }
</style>
