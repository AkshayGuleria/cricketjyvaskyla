---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MemberCard from '../components/MemberCard.astro';
import membersData from '../data/members.json';
---

<BaseLayout
  title="Members - Jyväskylä Cricket Club"
  description="Meet the executive committee and players of Jyväskylä Cricket Club for 2025."
>
  <Header slot="header" />

  <div class="container">
    <!-- Executive Committee -->
    <section class="members-section">
      <header class="page-hero reveal">
        <div class="page-hero-label">The Team</div>
        <h1>Executive Committee 2025</h1>
        <p class="page-hero-lead">The leadership team guiding Jyväskylä Cricket Club forward.</p>
      </header>

      <div class="members-grid reveal reveal-delay-1">
        {membersData.executive.map((member) => (
          <MemberCard
            name={member.name}
            role={member.role}
            email={member.email}
          />
        ))}
      </div>
    </section>

    <!-- Players -->
    <section class="members-section">
      <header class="section-head reveal">
        <div class="section-label">Squad</div>
        <h2>JCC Players 2025</h2>
        <p class="section-desc">Our talented squad of {membersData.players.length} players representing the club.</p>
      </header>

      <div class="members-grid reveal reveal-delay-1">
        {membersData.players.map((member) => (
          <MemberCard
            name={member.name}
            role={member.role}
          />
        ))}
      </div>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .members-section {
    margin-bottom: var(--space-4xl);
  }

  .page-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
    max-width: 680px;
  }

  .page-hero-label,
  .section-label {
    font-family: var(--font-accent);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    font-weight: 600;
    position: relative;
    padding-left: 2rem;
  }

  .page-hero-label::before,
  .section-label::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1.25rem;
    height: 1px;
    background: var(--color-accent);
  }

  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    line-height: 1.1;
  }

  .page-hero-lead,
  .section-desc {
    font-size: clamp(1.05rem, 1.5vw, 1.15rem);
    line-height: 1.7;
    color: var(--color-neutral-500);
  }

  .section-head {
    margin-bottom: var(--space-xl);
  }

  .section-head h2 {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .members-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
  }

  @media (max-width: 640px) {
    .page-hero {
      padding: var(--space-2xl) 0 var(--space-xl);
    }

    .members-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 641px) and (max-width: 1023px) {
    .members-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .members-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
