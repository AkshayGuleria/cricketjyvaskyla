---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Join Us - Jyväskylä Cricket Club"
  description="Join Jyväskylä Cricket Club - membership information, practice locations, and fees for both experienced players and beginners."
>
  <Header slot="header" />

  <div class="container">
    <!-- Page Header -->
    <header class="page-hero reveal">
      <div class="page-hero-label">Membership</div>
      <h1>Join the Club</h1>
      <p class="page-hero-lead">We welcome all those interested in cricket &mdash; experienced players and complete beginners alike.</p>
    </header>

    <!-- Cards -->
    <div class="info-row reveal reveal-delay-1">
      <article class="info-card">
        <div class="card-accent"></div>
        <h2>Home Ground</h2>
        <p>During summer (May to September) JCC outdoor matches take place at the Tikkakosken Liikuntapuisto, Jyväskylä.</p>
        <a href="https://maps.app.goo.gl/ZNHLoMhYoDEYpmpn8?g_st=iw" target="_blank" rel="noopener" class="card-link">
          View on Map <span aria-hidden="true">&rarr;</span>
        </a>
      </article>

      <article class="info-card">
        <div class="card-accent"></div>
        <h2>Practice Sessions</h2>
        <p>In September, indoor practice sessions begin in the University's U2 sports hall and last until April. From May onwards, outdoor sessions resume.</p>
        <a href="http://g.co/maps/w5gh3" target="_blank" rel="noopener" class="card-link">
          View on Map <span aria-hidden="true">&rarr;</span>
        </a>
      </article>
    </div>

    <!-- Fees -->
    <section class="fees-section reveal reveal-delay-2">
      <div class="section-label">Pricing</div>
      <h2>Membership Fee</h2>
      <div class="fees-grid">
        <div class="fee-card">
          <div class="fee-amount">&euro;100</div>
          <div class="fee-period">per person / year</div>
          <div class="fee-name">Full Membership</div>
          <p class="fee-desc">For those earning more than &euro;1500/month including PhD researchers.</p>
        </div>
        <div class="fee-card featured">
          <div class="fee-badge">Student Rate</div>
          <div class="fee-amount">&euro;50</div>
          <div class="fee-period">per person / year</div>
          <div class="fee-name">Half Membership</div>
          <p class="fee-desc">For those earning less than &euro;1500/month (undergraduate/graduate students and those unemployed).</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-band reveal reveal-delay-3">
      <div class="cta-content">
        <h3>Have Questions?</h3>
        <p>If you have more questions or queries, please feel free to contact us.</p>
        <a href="/contact" class="btn-accent">Contact Us</a>
      </div>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Page Hero */
  .page-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
    max-width: 680px;
  }

  .page-hero-label {
    font-family: var(--font-accent);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    font-weight: 600;
    position: relative;
    padding-left: 2rem;
  }

  .page-hero-label::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1.25rem;
    height: 1px;
    background: var(--color-accent);
  }

  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    line-height: 1.1;
  }

  .page-hero-lead {
    font-size: clamp(1.05rem, 1.5vw, 1.15rem);
    line-height: 1.7;
    color: var(--color-neutral-500);
  }

  /* Info Row */
  .info-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-4xl);
  }

  .info-card {
    background: var(--color-cream);
    border: 1px solid var(--color-cream-dark);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    position: relative;
    overflow: hidden;
    transition: box-shadow var(--transition-base);
  }

  .info-card:hover {
    box-shadow: var(--shadow-md);
  }

  .card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-accent);
  }

  .info-card h2 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .info-card p {
    color: var(--color-neutral-600);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .card-link {
    font-family: var(--font-accent);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: color var(--transition-base);
    display: inline;
    min-height: auto;
    min-width: auto;
  }

  .card-link:hover {
    color: var(--color-accent-dark);
    text-decoration: none;
  }

  .card-link:visited {
    color: var(--color-accent);
  }

  /* Fees Section */
  .fees-section {
    margin-bottom: var(--space-4xl);
  }

  .section-label {
    font-family: var(--font-accent);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    font-weight: 600;
    position: relative;
    padding-left: 2rem;
  }

  .section-label::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1.25rem;
    height: 1px;
    background: var(--color-accent);
  }

  .fees-section > h2 {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    color: var(--color-primary);
    margin-bottom: var(--space-xl);
  }

  .fees-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  .fee-card {
    background: var(--color-cream);
    border: 1px solid var(--color-cream-dark);
    border-radius: var(--radius-md);
    padding: var(--space-2xl) var(--space-xl);
    text-align: center;
    position: relative;
    transition: all var(--transition-base);
  }

  .fee-card:hover {
    box-shadow: var(--shadow-md);
  }

  .fee-card.featured {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .fee-badge {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    font-family: var(--font-accent);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    color: var(--color-gold-light);
    background: rgba(212, 168, 71, 0.12);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-full);
  }

  .fee-amount {
    font-family: var(--font-heading);
    font-size: 3rem;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .featured .fee-amount {
    color: var(--color-cream);
  }

  .fee-period {
    font-size: 0.82rem;
    color: var(--color-neutral-500);
    margin-bottom: var(--space-md);
  }

  .featured .fee-period {
    color: rgba(245, 240, 232, 0.4);
  }

  .fee-name {
    font-family: var(--font-accent);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .featured .fee-name {
    color: var(--color-gold-light);
  }

  .fee-desc {
    font-size: 0.9rem;
    color: var(--color-neutral-500);
    line-height: 1.6;
    margin: 0;
  }

  .featured .fee-desc {
    color: rgba(245, 240, 232, 0.5);
  }

  /* CTA Band */
  .cta-band {
    background: var(--color-cream);
    border: 1px solid var(--color-cream-dark);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    margin-bottom: var(--space-3xl);
    text-align: center;
  }

  .cta-content h3 {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .cta-content p {
    color: var(--color-neutral-500);
    margin-bottom: var(--space-lg);
  }

  .btn-accent {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--color-accent);
    color: var(--color-cream-light);
    font-family: var(--font-accent);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
  }

  .btn-accent:hover {
    background: var(--color-accent-dark);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(196, 74, 47, 0.3);
  }

  .btn-accent:visited {
    color: var(--color-cream-light);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .page-hero {
      padding: var(--space-2xl) 0 var(--space-xl);
    }

    .info-row {
      grid-template-columns: 1fr;
    }

    .fees-grid {
      grid-template-columns: 1fr;
    }

    .cta-band {
      padding: var(--space-xl);
    }
  }
</style>
