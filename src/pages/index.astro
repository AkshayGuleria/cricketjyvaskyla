---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Jyväskylä Cricket Club - Home">
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <h1 class="hero-title reveal reveal-delay-1">Jyväskylä Cricket Club</h1>
      <div class="hero-eyebrow reveal">Est. 2009</div>
      <p class="hero-lead reveal reveal-delay-2">Where the sport of Cricket meets the human community.</p>
      <div class="hero-actions reveal reveal-delay-3">
        <a href="/join_us/" class="btn-hero">Join the Club</a>
      </div>
    </div>

  </section>

  <div class="container">
    <!-- History Section -->
    <section class="editorial-section reveal">
      <div class="section-label">Our Story</div>
      <div class="editorial-grid">
        <div class="editorial-main">
          <h2>A Brief History</h2>
          <p class="editorial-intro">The City of Jyväskylä had never seen cricket before September 2008. That's when an amazing event transpired.</p>
          <p>That October, Ahmer Iqubal and Venkatesan (with the keen support of Jari Schabel) initiated a weekly indoor cricket session for other cricket enthusiasts.</p>
          <p>During the winter, the runs kept piling up and by February 2009, the club's first executive committee was formed. The club's eleven founding members made history on 3 June 2009, the day when the Jyväskylä Cricket Club ry (JCC) officially came into existence as a registered Finnish association.</p>
          <p>The club's first ever outdoor match (25-overs) was played in Tampere against TRE CC on 30 May 2010 at Messukylä. JCC hosted their first home series, two T20 friendly matches, also against TRE CC on 25 July at their home ground in Keltinmäki.</p>
        </div>
        <aside class="editorial-aside">
          <img src="/images/jcc_logo.jpg" alt="JCC Logo" class="aside-image" />
          <div class="aside-stat">
            <span class="stat-number">2009</span>
            <span class="stat-label">Founded</span>
          </div>
        </aside>
      </div>
    </section>

    <!-- Join CTA -->
    <section class="cta-band reveal">
      <div class="cta-content">
        <h2>Ready to Play?</h2>
        <p>JCC welcomes all those interested in cricket, both experienced players and complete beginners. During summer we train outdoors at Kotalampi field, and in winter at the University's U1 sports hall.</p>
        <a href="/join_us/" class="btn-accent">Learn About Membership</a>
      </div>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ===================================
     Hero
     =================================== */
  .hero {
    background: var(--color-primary);
    position: relative;
    overflow: hidden;
    min-height: 35vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 80%, rgba(196, 74, 47, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(45, 106, 79, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--space-2xl) var(--space-lg);
    max-width: 800px;
  }

  .hero-eyebrow {
    font-family: var(--font-accent);
    font-size: 1.20rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-gold-light);
    margin-bottom: var(--space-lg);
    font-weight: 500;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    font-weight: 400;
    color: var(--color-cream);
    line-height: 1.05;
    margin-bottom: var(--space-xl);
    letter-spacing: -0.03em;
  }

  .hero-lead {
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    color: rgba(240, 239, 237, 0.85);
    line-height: 1.7;
    margin-bottom: var(--space-2xl);
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-hero {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--color-accent);
    color: var(--color-cream-light);
    font-family: var(--font-accent);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
  }

  .btn-hero:hover {
    background: var(--color-accent-dark);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(196, 74, 47, 0.3);
  }

  .btn-hero:visited {
    color: var(--color-cream-light);
  }

  .btn-hero-outline {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: transparent;
    color: rgba(245, 240, 232, 0.7);
    font-family: var(--font-accent);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid rgba(245, 240, 232, 0.2);
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
  }

  .btn-hero-outline:hover {
    border-color: rgba(245, 240, 232, 0.5);
    color: var(--color-cream);
    text-decoration: none;
  }

  .btn-hero-outline:visited {
    color: rgba(245, 240, 232, 0.7);
  }

  .hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(to top, var(--color-cream-light), transparent);
    pointer-events: none;
  }

  /* ===================================
     Editorial Section
     =================================== */
  .editorial-section {
    padding: var(--space-4xl) 0;
  }

  .section-label {
    font-family: var(--font-accent);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin-bottom: var(--space-xl);
    font-weight: 600;
    position: relative;
    padding-left: 2rem;
  }

  .section-label::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1.25rem;
    height: 1px;
    background: var(--color-accent);
  }

  .editorial-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-3xl);
    align-items: start;
  }

  .editorial-main h2 {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    color: var(--color-primary);
    margin-bottom: var(--space-xl);
    line-height: 1.15;
  }

  .editorial-intro {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-neutral-600);
    margin-bottom: var(--space-lg);
    font-weight: 400;
  }

  .editorial-main p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-neutral-600);
    margin-bottom: var(--space-md);
  }

  /* Aside */
  .editorial-aside {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .aside-image {
    width: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-cream-dark);
  }

  .aside-stat {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
    background: var(--color-cream);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--color-accent);
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 2rem;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-accent);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-neutral-500);
    margin-top: 0.375rem;
    font-weight: 500;
  }

  /* ===================================
     CTA Band
     =================================== */
  .cta-band {
    background: var(--color-primary);
    border-radius: var(--radius-lg);
    padding: var(--space-3xl);
    margin-bottom: var(--space-3xl);
    position: relative;
    overflow: hidden;
  }

  .cta-band::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(196, 74, 47, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    z-index: 1;
    max-width: 600px;
  }

  .cta-content h2 {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    color: var(--color-cream);
    margin-bottom: var(--space-md);
  }

  .cta-content p {
    color: rgba(245, 240, 232, 0.6);
    font-size: 1.02rem;
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .btn-accent {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--color-accent);
    color: var(--color-cream-light);
    font-family: var(--font-accent);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
  }

  .btn-accent:hover {
    background: var(--color-accent-dark);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(196, 74, 47, 0.3);
  }

  .btn-accent:visited {
    color: var(--color-cream-light);
  }

  /* ===================================
     Responsive
     =================================== */
  @media (max-width: 768px) {
    .hero {
      min-height: 65vh;
    }

    .hero-inner {
      padding: var(--space-3xl) var(--space-md);
    }

    .editorial-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .editorial-aside {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-md);
    }

    .aside-image {
      max-width: 140px;
    }

    .aside-stat {
      flex: 1;
      min-width: 120px;
    }

    .cta-band {
      padding: var(--space-2xl) var(--space-lg);
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: 60vh;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .btn-hero,
    .btn-hero-outline {
      width: 100%;
      max-width: 260px;
      justify-content: center;
    }
  }
</style>
