---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact - Jyväskylä Cricket Club"
  description="Get in touch with Jyväskylä Cricket Club. Contact details for the Chairman and Secretary."
>
  <Header slot="header" />

  <div class="container">
    <header class="page-hero reveal">
      <div class="page-hero-label">Get in Touch</div>
      <h1>Contact Us</h1>
      <p class="page-hero-lead">Reach out to the Jyväskylä Cricket Club leadership team.</p>
    </header>

    <!-- Contact Cards -->
    <div class="contact-row reveal reveal-delay-1">
      <article class="contact-card">
        <div class="contact-role">Chairman</div>
        <h2 class="contact-name">Akshay Guleria</h2>
        <a href="mailto:chairman@cricketjyvaskyla.com" class="contact-email">
          chairman@cricketjyvaskyla.com
        </a>
        <p class="contact-desc">For general inquiries, membership questions, and club matters.</p>
      </article>

      <article class="contact-card">
        <div class="contact-role">Secretary</div>
        <h2 class="contact-name">Shehriyar Arif</h2>
        <a href="mailto:secretary@cricketjyvaskyla.com" class="contact-email">
          secretary@cricketjyvaskyla.com
        </a>
        <p class="contact-desc">For official correspondence and administrative matters.</p>
      </article>
    </div>

    <!-- Quick Info -->
    <div class="info-strip reveal reveal-delay-2">
      <div class="info-item">
        <span class="info-label">Location</span>
        <span class="info-value">Jyväskylä, Central Finland</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-item">
        <span class="info-label">Home Ground</span>
        <span class="info-value">
          <a href="https://maps.app.goo.gl/ZNHLoMhYoDEYpmpn8?g_st=iw" target="_blank" rel="noopener">Tikkakosken Liikuntapuisto</a>
        </span>
      </div>
      <div class="info-divider"></div>
      <div class="info-item">
        <span class="info-label">Founded</span>
        <span class="info-value">June 3, 2009</span>
      </div>
    </div>

    <!-- Social -->
    <section class="social-cta reveal reveal-delay-3">
      <h3>Interested in Joining?</h3>
      <p>Check out our <a href="/join_us">membership options</a> and become part of our growing cricket community.</p>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
    max-width: 680px;
  }

  .page-hero-label {
    font-family: var(--font-accent);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    font-weight: 600;
    position: relative;
    padding-left: 2rem;
  }

  .page-hero-label::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1.25rem;
    height: 1px;
    background: var(--color-accent);
  }

  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    line-height: 1.1;
  }

  .page-hero-lead {
    font-size: clamp(1.05rem, 1.5vw, 1.15rem);
    line-height: 1.7;
    color: var(--color-neutral-500);
  }

  /* Contact Row */
  .contact-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-3xl);
    max-width: 800px;
  }

  .contact-card {
    background: var(--color-cream);
    border: 1px solid var(--color-cream-dark);
    border-radius: var(--radius-md);
    padding: var(--space-2xl) var(--space-xl);
    transition: box-shadow var(--transition-base);
  }

  .contact-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .contact-role {
    font-family: var(--font-accent);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-gold);
    margin-bottom: var(--space-sm);
    font-weight: 600;
  }

  .contact-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .contact-email {
    display: inline-block;
    font-size: 0.92rem;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.6rem 1.25rem;
    background: rgba(196, 74, 47, 0.06);
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
    margin-bottom: var(--space-md);
    min-height: auto;
    min-width: auto;
    font-weight: 500;
  }

  .contact-email:hover {
    background: var(--color-accent);
    color: var(--color-cream-light);
    text-decoration: none;
  }

  .contact-email:visited {
    color: var(--color-accent);
  }

  .contact-email:visited:hover {
    color: var(--color-cream-light);
  }

  .contact-desc {
    font-size: 0.92rem;
    color: var(--color-neutral-500);
    line-height: 1.6;
    margin: 0;
  }

  /* Info Strip */
  .info-strip {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    padding: var(--space-xl) var(--space-2xl);
    background: var(--color-primary);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-3xl);
    max-width: 800px;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .info-label {
    font-family: var(--font-accent);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold-light);
    font-weight: 500;
  }

  .info-value {
    font-size: 0.95rem;
    color: var(--color-cream);
  }

  .info-value a {
    color: var(--color-cream);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: rgba(245, 240, 232, 0.3);
    transition: text-decoration-color var(--transition-base);
    display: inline;
    min-height: auto;
    min-width: auto;
  }

  .info-value a:visited {
    color: var(--color-cream);
  }

  .info-value a:hover {
    text-decoration-color: var(--color-cream);
  }

  .info-divider {
    width: 1px;
    height: 36px;
    background: rgba(245, 240, 232, 0.1);
  }

  /* Social CTA */
  .social-cta {
    max-width: 600px;
    padding: var(--space-2xl);
    background: var(--color-cream);
    border: 1px solid var(--color-cream-dark);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-3xl);
  }

  .social-cta h3 {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .social-cta p {
    color: var(--color-neutral-500);
    line-height: 1.7;
    margin: 0;
  }

  .social-cta a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    display: inline;
    min-height: auto;
    min-width: auto;
  }

  .social-cta a:visited {
    color: var(--color-accent);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .contact-row {
      grid-template-columns: 1fr;
    }

    .info-strip {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-md);
      padding: var(--space-xl);
    }

    .info-divider {
      width: 100%;
      height: 1px;
    }
  }

  @media (max-width: 640px) {
    .page-hero {
      padding: var(--space-2xl) 0 var(--space-xl);
    }
  }
</style>
