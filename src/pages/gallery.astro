---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Gallery from '../components/Gallery.astro';
import galleryData from '../data/gallery.json';
---

<BaseLayout
  title="Gallery - Jyväskylä Cricket Club"
  description="Browse photos from Jyväskylä Cricket Club matches, events, and memorable moments."
>
  <Header slot="header" />

  <div class="container">
    <header class="page-hero reveal">
      <div class="page-hero-label">Moments</div>
      <h1>Photo Gallery</h1>
      <p class="page-hero-lead">Relive the best moments from our matches, tournaments, and club events.</p>
    </header>

    <div class="gallery-content">
      {galleryData.albums.map((album) => (
        <section class="album-section reveal">
          <div class="album-head">
            <h2>{album.title}</h2>
            <p class="album-desc">{album.description}</p>
            <div class="album-meta">
              <span class="meta-tag">{album.date}</span>
              <span class="meta-tag">{album.location}</span>
              {album.images.length > 0 && (
                <span class="meta-tag">{album.images.length} photos</span>
              )}
            </div>
          </div>

          <Gallery images={album.images} albumId={album.id} />
        </section>
      ))}

      <!-- CTA -->
      <section class="cta-band reveal">
        <div class="cta-content">
          <h3>Have Photos to Share?</h3>
          <p>If you have photos from club events or matches that you'd like to contribute, please get in touch.</p>
          <a href="/contact/" class="btn-accent">Contact Us</a>
        </div>
      </section>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
    max-width: 680px;
  }

  .page-hero-label {
    font-family: var(--font-accent);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    font-weight: 600;
    position: relative;
    padding-left: 2rem;
  }

  .page-hero-label::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1.25rem;
    height: 1px;
    background: var(--color-accent);
  }

  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    line-height: 1.1;
  }

  .page-hero-lead {
    font-size: clamp(1.05rem, 1.5vw, 1.15rem);
    line-height: 1.7;
    color: var(--color-neutral-500);
  }

  .gallery-content {
    max-width: 1100px;
  }

  /* Album Section */
  .album-section {
    margin-bottom: var(--space-4xl);
    padding-bottom: var(--space-3xl);
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .album-section:last-of-type {
    border-bottom: none;
  }

  .album-head {
    margin-bottom: var(--space-xl);
  }

  .album-head h2 {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .album-desc {
    font-size: 1rem;
    color: var(--color-neutral-500);
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .album-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .meta-tag {
    font-family: var(--font-accent);
    font-size: 0.78rem;
    color: var(--color-neutral-500);
    padding: 0.3rem 0.75rem;
    background: var(--color-cream);
    border: 1px solid var(--color-cream-dark);
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
  }

  /* CTA */
  .cta-band {
    background: var(--color-cream);
    border: 1px solid var(--color-cream-dark);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .cta-content h3 {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .cta-content p {
    color: var(--color-neutral-500);
    margin-bottom: var(--space-lg);
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .btn-accent {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--color-accent);
    color: var(--color-cream-light);
    font-family: var(--font-accent);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
  }

  .btn-accent:hover {
    background: var(--color-accent-dark);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(196, 74, 47, 0.3);
  }

  .btn-accent:visited {
    color: var(--color-cream-light);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .page-hero {
      padding: var(--space-2xl) 0 var(--space-xl);
    }

    .album-section {
      margin-bottom: var(--space-2xl);
      padding-bottom: var(--space-2xl);
    }

    .cta-band {
      padding: var(--space-xl);
    }
  }
</style>
