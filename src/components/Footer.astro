---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Top section with decorative line -->
    <div class="footer-rule">
      <span class="footer-rule-accent"></span>
    </div>

    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <span class="footer-logo-text">Jyväskylä Cricket Club</span>
        <p class="footer-tagline">Promoting cricket in Central Finland since 2009.</p>
        <p class="footer-reg">Registered as Jyväskylä Cricket Club ry</p>
      </div>

      <!-- Navigate -->
      <div class="footer-col">
        <h3 class="footer-heading">Navigate</h3>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/members">Members</a></li>
          <li><a href="/join_us">Join Us</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div class="footer-col">
        <h3 class="footer-heading">Resources</h3>
        <ul class="footer-links">
          <li><a href="/fixtures">Fixtures</a></li>
          <li><a href="/gallery">Gallery</a></li>
          <li><a href="/expense_form">Expenses</a></li>
          <li><a href="/pdfs/by-laws/" target="_blank" rel="noopener">Bylaws</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h3 class="footer-heading">Get in Touch</h3>
        <a href="mailto:info@cricketjyvaskyla.com" class="footer-email">
          info@cricketjyvaskyla.com
        </a>
        <p class="footer-location">Jyväskylä, Finland</p>
      </div>
    </div>

    <!-- Bottom -->
    <div class="footer-bottom">
      <p class="footer-copy">&copy; {currentYear} <a href="/">cricketjyvaskyla.com</a></p>
      <p class="footer-credit">Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a></p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-primary);
    color: rgba(245, 240, 232, 0.6);
    margin-top: var(--space-5xl);
  }

  .footer-inner {
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  /* Decorative rule */
  .footer-rule {
    padding-top: 3rem;
    margin-bottom: 3rem;
    position: relative;
  }

  .footer-rule::before {
    content: '';
    display: block;
    height: 1px;
    background: rgba(245, 240, 232, 0.08);
  }

  .footer-rule-accent {
    position: absolute;
    top: 3rem;
    left: 0;
    width: 48px;
    height: 1px;
    background: var(--color-accent);
  }

  /* Grid */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-logo-text {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--color-cream);
  }

  .footer-tagline {
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    color: rgba(245, 240, 232, 0.5);
  }

  .footer-reg {
    font-size: 0.82rem;
    margin: 0;
    color: rgba(245, 240, 232, 0.3);
  }

  /* Columns */
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-heading {
    font-family: var(--font-accent);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-gold-light);
    margin-bottom: 0.25rem;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links li { margin: 0; }

  .footer-links a {
    color: rgba(245, 240, 232, 0.5);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color var(--transition-base);
    display: inline;
    min-height: auto;
    min-width: auto;
  }

  .footer-links a:visited {
    color: rgba(245, 240, 232, 0.5);
  }

  .footer-links a:hover {
    color: var(--color-cream);
    text-decoration: none;
  }

  .footer-email {
    color: rgba(245, 240, 232, 0.5);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color var(--transition-base);
    display: inline;
    min-height: auto;
    min-width: auto;
    word-break: break-word;
  }

  .footer-email:visited {
    color: rgba(245, 240, 232, 0.5);
  }

  .footer-email:hover {
    color: var(--color-cream);
    text-decoration: none;
  }

  .footer-location {
    font-size: 0.9rem;
    margin: 0;
    color: rgba(245, 240, 232, 0.35);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(245, 240, 232, 0.06);
    padding: 1.5rem 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copy,
  .footer-credit {
    font-size: 0.8rem;
    color: rgba(245, 240, 232, 0.3);
    margin: 0;
  }

  .footer-bottom a {
    color: rgba(245, 240, 232, 0.4);
    text-decoration: none;
    transition: color var(--transition-base);
    display: inline;
    min-height: auto;
    min-width: auto;
  }

  .footer-bottom a:visited {
    color: rgba(245, 240, 232, 0.4);
  }

  .footer-bottom a:hover {
    color: var(--color-cream);
    text-decoration: none;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .footer-inner {
      padding: 0 var(--space-md);
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }

  @media (min-width: 641px) and (max-width: 1023px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .footer-inner {
      padding: 0 var(--space-2xl);
    }
  }

  @media print {
    .site-footer {
      background: white;
      color: black;
      border-top: 2px solid black;
      margin-top: var(--space-xl);
    }

    .footer-grid { display: none; }
    .footer-rule { display: none; }
    .footer-credit { display: none; }
  }
</style>
